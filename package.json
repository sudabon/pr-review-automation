{
  "name": "ai-dev-loop",
  "version": "0.1.0",
  "description": "Local AI review, fix, validation, and re-review loop for pull request changes.",
  "type": "module",
  "bin": {
    "ai-dev-loop": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "execa": "^9.6.0",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.0"
}
